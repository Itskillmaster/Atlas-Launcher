{
  "name": "atlas-launcher",
  "version": "0.0.3",
  "main": "main.js",
  "description": "The Best Iranian Launcher.",
  "author": "SMR",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win -p always",
    "server": "node server.js",
    "add-user": "node add-user.js"
  },
  "keywords": [],
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "discord-rpc": "^4.0.1",
    "dotenv": "^16.3.1",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.1"
  },
  "devDependencies": {
    "electron": "^37.7.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.atlaslauncher.app",
    "productName": "Atlas Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://ph0enix.ir/updates/"
      }
    ]
  }
}
